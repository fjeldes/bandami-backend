# Backend - Environment Variables
# Copy this file to .env for local development
# For production, set these in GitHub Secrets → BACKEND_ENV_VARS (comma-separated KEY=val)

# PostgreSQL (local Docker: postgresql://ielts:ielts@db:5432/ielts)
# PostgreSQL (Supabase):   postgresql://postgres:{password}@db.{ref}.supabase.co:5432/postgres
DATABASE_URL=postgresql://ielts:ielts@db:5432/ielts

# OpenAI — used for detailed evaluation
OPENAI_API_KEY=sk-...

# Google Gemini — used for evaluation
GEMINI_API_KEY=AIza...

# Auth — JWT
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-at-least-64-chars

# Auth — Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Brevo — Transactional Emails (300/día gratis)
# API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...
BREVO_FROM_EMAIL=Bandami <contacto@bandami.com>

# Paddle — Merchant of record (global tax compliance, international)
# Sandbox: https://sandbox-api.paddle.com
# Production: https://api.paddle.com
PAYMENT_PROVIDER=paddle
PADDLE_API_KEY=pdl_sdbx_apikey_...
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...
PADDLE_ENVIRONMENT=sandbox
PADDLE_PRICE_PREMIUM=pri_01ktwffvqm5s1dv0184f83hqt0
#
# Flow.cl — Chile payment provider (backup, for Chile-based businesses)
# Sandbox: https://sandbox.flow.cl → Mis datos → Integración
# Production: https://flow.cl → Mis datos → Integración
# FLOW_API_KEY=tu_api_key
# FLOW_SECRET_KEY=tu_secret_key
# FLOW_ENVIRONMENT=sandbox
#
# Stripe — Payments (deprecated, for reference)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PREMIUM=price_...

# Frontend URL (for email links + CORS + checkout redirects)
FRONTEND_URL=http://localhost:3000

# Backend URL (for Flow webhooks + card-callback)
# Cuando pruebas local, usar: ngrok http 8000 y poner la URL de ngrok aquí
# En producción, es la URL de Cloud Run
BACKEND_URL=http://localhost:8000

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# App
ENVIRONMENT=development
DEBUG=true
