# Backend - Environment Variables
# Copy this file to .env for local development
# For production, set these in GitHub Secrets → BACKEND_ENV_VARS (comma-separated KEY=val)

# PostgreSQL (local Docker: postgresql://ielts:ielts@db:5432/ielts)
# PostgreSQL (Supabase):   postgresql://postgres:{password}@db.{ref}.supabase.co:5432/postgres
DATABASE_URL=postgresql://ielts:ielts@db:5432/ielts

# OpenAI (Premium - GPT-4o + Whisper)
OPENAI_API_KEY=sk-...

# Google Gemini (Free tier - $0 cost, 1500 req/day)
GEMINI_API_KEY=AIza...

# Auth — JWT
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-at-least-64-chars

# Auth — Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Brevo — Transactional Emails (300/día gratis)
# API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...
BREVO_FROM_EMAIL=Bandami <contacto@bandami.com>

# Stripe — Payments
# Production: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_CREDIT_10=price_...
STRIPE_PRICE_CREDIT_25=price_...
STRIPE_PRICE_EXAM_WEEK=price_...

# Paddle — Alternative payment provider (Merchant of Record)
# Set PAYMENT_PROVIDER=paddle to switch from Stripe
PAYMENT_PROVIDER=stripe
PADDLE_API_KEY=pdl_test_...
PADDLE_WEBHOOK_SECRET=whsec_...
PADDLE_PRICE_PREMIUM=pri_...
PADDLE_PRICE_EXAM_WEEK=pri_...
PADDLE_ENVIRONMENT=sandbox

# Frontend URL (for email links + CORS + checkout redirects)
FRONTEND_URL=http://localhost:3000

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# App
ENVIRONMENT=development
DEBUG=true
